MONGODB_URI=your-mongodb-connection-string
OPENAI_API_KEY=your-openai-key
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
SHOPIFY_API_KEY=your_key
SHOPIFY_API_SECRET=your_secret
SHOPIFY_ACCESS_TOKEN=your_access_token
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
RUN_WORKER=true
# How many DetectRuns process concurrently in this worker process.
# Default 2 (safe on Render free tier 512MB). Bump up on paid plans:
#   Standard 2GB → 8-10
#   Pro      4GB → 20-30
#   Pro Plus 8GB → 50+
# Pipeline is mostly I/O so memory is the real ceiling. Cap is 100.
# Mongoose pool sizes itself to 3× concurrency (capped at 200) to
# avoid head-of-line blocking at high concurrency.
WORKER_CONCURRENCY=2

# Gemini (detect pipeline, extended-ratio candidates + grounded product search)
# AI Studio key, 39 chars, prefix "AIza..." — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-ai-studio-key
# Optional: pin a specific model for image generation. If unset, ListModels picks
# the first image-capable one. e.g. gemini-2.5-flash-image, gemini-3.1-flash-image-preview
GEMINI_IMAGE_MODEL=
# Model used for grounded product-match search (text-based). Default gemini-2.5-flash.
GEMINI_SEARCH_MODEL=

# SerpAPI — Google Lens visual product matching (detect pipeline, product-match stage)
# Get from https://serpapi.com/dashboard
SERPAPI_API_KEY=your-serpapi-key
# Optional: country biasing for Google Lens results. Default "us".
SERPAPI_COUNTRY=

# Brandfetch — brand-kit lookup (logo, colors, fonts) by domain. Used by
# brand enrichment as the primary visual-identity source; falls back to
# homepage scraping (apple-touch-icon + Google Fonts links + meta theme-color)
# when missing or 404. Get from https://developers.brandfetch.com/
BRANDFETCH_API_KEY=your-brandfetch-key

# Google OAuth — USER LOGIN client. Should be a SEPARATE OAuth client
# from the Google Ads one below. This one only requests basic scopes
# (email, profile, openid) so the consent screen can be PUBLISHED
# without going through Google's sensitive-scope verification process
# (1–2 week review). With this client published, anyone with a Google
# account can sign in without being added to a Test users allowlist.
#
# Setup (Google Cloud Console):
#   1. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   2. Application type: Web application
#   3. Authorized redirect URIs: <this backend's domain>/auth/google/callback
#   4. APIs & Services → OAuth consent screen → Publishing status → PUBLISH
#      (no verification needed for basic scopes)
GOOGLE_CLIENT_ID=your-google-login-client-id
GOOGLE_CLIENT_SECRET=your-google-login-client-secret
GOOGLE_CALLBACK_URL=https://liquidretail-backend.onrender.com/auth/google/callback
SESSION_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string

# Where the backend bounces users after OAuth (Google signin + IG /
# Meta Ads / Google Ads callbacks land on this domain's hash/query).
# Defaults to https://liquidretail.netlify.app when unset.
# Set on a dev/staging backend to point at the dev frontend domain.
FRONTEND_URL=

# Meta / Instagram OAuth (Phase A — Connect Instagram on brand page).
# Register a Business app at https://developers.facebook.com/apps/, add
# the Facebook Login product, set Valid OAuth Redirect URIs to the
# callback URL below, and request these permissions during App Review:
# instagram_basic, pages_show_list, pages_read_engagement,
# business_management, catalog_management.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/instagram/callback
# Optional: pin a specific Graph API version. Default v19.0.
META_API_VERSION=

# AES-256 key for encrypting third-party access tokens at rest. Must be
# 32 bytes base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENCRYPTION_KEY=base64-32-bytes-here

# Meta webhook verify token (V3 #1). Arbitrary string you also paste
# into the Meta App Dashboard when setting up the webhook subscription;
# Meta echoes it back during the GET verification handshake.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
META_WEBHOOK_VERIFY_TOKEN=any-long-random-string

# Meta Ads OAuth callback (Ad Platforms Phase A). Same Meta App as the
# IG integration above, just a separate Valid OAuth Redirect URI for
# ads scopes (ads_read, ads_management, business_management). Add this
# URL to the same Meta App's Facebook Login → Valid OAuth Redirect URIs.
META_ADS_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/meta-ads/callback

# Google Ads OAuth — SENSITIVE-SCOPE client. Use a SEPARATE OAuth client
# from the login one above. This one requests the adwords scope, which
# Google flags as sensitive — the consent screen cannot be published
# without going through OAuth verification (privacy policy, demo video,
# 1–2 week review). Keep this client in TESTING mode and add the operators
# who will link Google Ads accounts to the Test users allowlist (max 100).
#
# Splitting this from the login client means: login is open to anyone
# (no allowlist), and only the few users who actually link a Google Ads
# account need to be on the Test users allowlist.
#
# Setup (Google Cloud Console — same project as login is fine, or the
# project whose developer-token app is approved for Google Ads):
#   1. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   2. Application type: Web application
#   3. Authorized redirect URIs: <this backend's domain>/api/integrations/google-ads/callback
#   4. OAuth consent screen → leave Publishing status as Testing
#   5. OAuth consent screen → Test users → add operator emails
#
# If GOOGLE_ADS_CLIENT_ID is unset, the service falls back to
# GOOGLE_CLIENT_ID/SECRET above — convenient for single-client dev but
# couples your login users to the sensitive-scope verification gate.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=https://liquidretail-backend.onrender.com/api/integrations/google-ads/callback

# Google Ads Developer Token. Server-wide secret required by every
# Google Ads API call. Apply at https://ads.google.com/aw/apicenter
# (test access is granted instantly; production requires Google review).
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# Optional: pin the Google Ads API version used by REST calls. Default v17.
GOOGLE_ADS_API_VERSION=

# ── Video generation provider ────────────────────────────────────────
#
# The video pipeline ships with two providers behind videoRouter.js:
#   vertex (default) — Vertex AI Veo 3.1 direct. Uses GEMINI_API_KEY.
#   atlas            — Atlas Cloud, defaulting to Gemini Omni Flash
#                      image-to-video (google/gemini-omni-flash/
#                      image-to-video-developer): Ken Burns camera-only
#                      animation over the supplied product photos,
#                      8s @ 24fps, up to 7 reference images (default 3).
#                      ≈$1.00 per 8s/720p render (see
#                      atlasVideoService.estimateRenderCostUsd; every
#                      render logs a CostLog entry, stage
#                      'atlas_video_render').
#
# Output is motion-only on both providers — all on-screen text is
# composited downstream by the brand-script overlay.
#
# Switch by setting VIDEO_PROVIDER=atlas (defaults to vertex when unset).
VIDEO_PROVIDER=vertex

# Atlas Cloud — required when VIDEO_PROVIDER=atlas.
ATLAS_API_KEY=
# Override the Atlas model deployment-wide. Defaults to
# google/gemini-omni-flash/image-to-video-developer. Per-brand and
# per-product overrides (Brand.videoSettings / CatalogProduct.videoSettings
# — flat `model` or per-canvas `modelByCanvas`) take precedence over this
# env. Slugs must exist in atlasVideoService.MODEL_CAPS (the legacy Grok
# default xai/grok-imagine-video/reference-to-video remains registered).
# Available video models documented at https://www.atlascloud.ai/docs/models/video
ATLAS_VIDEO_MODEL=
# Output resolution for the Gemini Omni default (720p | 1080p | 4k).
# Defaults to 720p; 1080p costs the same, 4k adds $0.80/render.
ATLAS_VIDEO_RESOLUTION=
# How many reference images ship per generation (1–7). Defaults to 3
# (primary image + first two alt views). Per-brand/per-product
# videoSettings.referenceImageCount overrides this env.
ATLAS_REFERENCE_IMAGE_COUNT=

# Optional tuning. Defaults: 5s poll interval, 10min timeout.
ATLAS_POLL_INTERVAL_MS=
ATLAS_TIMEOUT_MS=
# Rate-limit backoff schedule (comma-separated ms), e.g. 30000,60000,120000.
# Defaults tuned for Grok's 1 RPS; Gemini Omni's Atlas limit is unpublished.
ATLAS_RATE_LIMIT_BACKOFF_MS=
# Optional override (e.g., for staging tenant). Defaults to https://api.atlascloud.ai/api/v1
ATLAS_BASE_URL=
# Claude model used by services/atlasTextService.js (brand-script
# generation, other text tasks). Defaults to anthropic/claude-sonnet-4.6.
# Bump to anthropic/claude-opus-4.7 for tasks that need more reasoning.
ATLAS_TEXT_MODEL_ID=
# Text endpoints live at /v1 (NOT /api/v1 like video). Override only
# if Atlas moves the text path or you're pointing at a staging tenant.
# Defaults to https://api.atlascloud.ai/v1
ATLAS_TEXT_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# Sales Demos — Apify-backed public scrape for demo Brands. One shared
# server token; per-brand handle/URL is stored on Brand.apifyDemo.
# Demo brands live under the auto-seeded "Sales Demos" Advertiser.
# ─────────────────────────────────────────────────────────────────────
APIFY_TOKEN=
# Actor slugs. Override if we swap to community actors.
APIFY_IG_ACTOR=apify/instagram-scraper
APIFY_SHOPIFY_ACTOR=apify/shopify-scraper
# Per-source result caps per sync run. Defaults are sweet-spot for
# demo brands (IG 50 posts, Shopify 200 products). Bump for larger
# catalogs; be aware of downstream enrichment cost (~$0.05-0.12 per
# Shopify product enrichment).
APIFY_IG_LIMIT=50
APIFY_SHOPIFY_LIMIT=200
# Apify proxy group. Leave empty for default (datacenter). Set to
# RESIDENTIAL when a target Shopify store or IG account is firewalled
# against datacenter IPs (403s / anti-scrape blocks). Residential
# costs 5-10x more per GB — only enable when needed.
#   ''             default datacenter (cheapest)
#   RESIDENTIAL    real-user IPs (bypasses most firewalls, expensive)
#   AUTO           actor picks per hostname
APIFY_PROXY_GROUP=
# Comma-separated emails allowed to bootstrap the Sales Demos workspace
# (via /sales-demos "Set up workspace" button). After the first admin
# lands, additional sales reps get invited via the normal Team invite
# flow. Case-insensitive.
SALES_DEMOS_ADMINS=
