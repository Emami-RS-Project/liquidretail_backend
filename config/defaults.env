# config/defaults.env — non-sensitive runtime configuration, versioned WITH the repo.
#
# WHY: feature flags, tuning knobs, and public identifiers/URLs used to live
# only as Render dashboard env vars, which meant every change required a
# manual dashboard edit and the current config wasn't visible in code review.
# They now live here and travel with the repo. SECRETS DO NOT — API keys,
# tokens, DB URIs, OAuth client secrets, and signing/encryption keys stay in
# the Render environment (see the "stays in Render env" list in docs/PIPELINES.md).
#
# PRECEDENCE (see index.js / worker.js): the process environment (Render env,
# or a local .env) is loaded FIRST and always wins; this file only fills vars
# that aren't already set. So you can still override any value per-environment
# via Render env without editing this file — and until the migrated vars are
# removed from the Render dashboard, they shadow these defaults (zero-change
# rollout). NEVER put a secret in this file; it is committed to git.

# ── AI creative pipeline feature flags ───────────────────────────────
AI_CONCEPT_DRIVEN=true
AI_HTML_LAYOUT_ENABLED=true
AI_LAYOUT_DIRECT_HTML=true
CANONICAL_DR_V1=true
RENDER_USE_HTML=true
RENDER_USE_RESOLVED=true

# Static-image ad production path. The default ad image is authored by
# GPT-4.1 as an HTML/CSS layout, rasterized by Puppeteer, then (when
# AI_IMAGE_REFERENCE_ENABLED) re-rendered by an image model for a photoreal
# finish. AI_IMAGE_REF_MODEL_ID selects that model (currently gpt-image-2).
# NOTE: IMAGE_REF_DUMP_SEEDS uploads every seed screenshot — a diagnostic;
# consider setting false to cut Cloudinary writes once tuning is done.
AI_IMAGE_REFERENCE_ENABLED=TRUE
AI_IMAGE_REF_MODEL_ID=gpt-image-2
AI_IMAGE_REF_QUALITY=high
IMAGE_REF_DUMP_SEEDS=true

# ── Video (Veo / Atlas) ──────────────────────────────────────────────
AI_VEO_FEED=true
AI_VEO_REELS=true
AI_VIDEO_POSTER_ENABLED=true
AI_OVERLAY_POLISH_ENABLED=false
VIDEO_PROVIDER=atlas
VEO_USE_GPT_STORYBOARD=true
ATLAS_VIDEO_FORCE_CHROME=true
ATLAS_VIDEO_MODEL=
ATLAS_POLL_INTERVAL_MS=15000
# Generative reframe of video reference images (outpaint to target aspect).
REFRAME_ENABLED=true
REFRAME_OUTPAINT_MODEL=google/nano-banana-2/edit-developer
REFRAME_RESOLUTION=4k
REFRAME_SKIP_THRESHOLD=0.985
REFRAME_COST_USD=0.04

# ── Concurrency (see docs/PIPELINES.md; VEO stays 1 — provider 429s) ──
WORKER_CONCURRENCY=5
RENDER_CONCURRENCY=4
VEO_CONCURRENCY=1

# ── Ingest tuning ────────────────────────────────────────────────────
APIFY_IG_ACTOR=apify/instagram-scraper
APIFY_IG_LIMIT=10
APIFY_SHOPIFY_ACTOR=webdatalabs/shopify-product-scraper
APIFY_SHOPIFY_LIMIT=50
APIFY_PROXY_GROUP=RESIDENTIAL
POST_FETCH_LIMIT=50
CATALOG_SYNC_MAX_ITEMS=250
CATALOG_VISUAL_MATCH_MAX_IMAGES=1

# ── Generic catalog scraper (sitemap + JSON-LD) ──────────────────────
# GENERIC_CATALOG_ENABLED kill-switch (default on unless 'false').
# GENERIC_CATALOG_LIMIT / _MAX_SITEMAP_URLS bound a first sync's cost.
# GENERIC_CATALOG_PDP_CONCURRENCY: parallel product-page fetches (the scan
#   still respects each host's crawl-delay + httpScrapeClient's min-gap).
GENERIC_CATALOG_ENABLED=true
GENERIC_CATALOG_LIMIT=10000
GENERIC_CATALOG_MAX_SITEMAP_URLS=20000
GENERIC_CATALOG_PDP_CONCURRENCY=5
HTTP_SCRAPE_MIN_GAP_MS=250

# ── Catalog detect + enrichment (deferred / gap-fill; see docs) ──────
# CATALOG_DETECT_PRECOMPUTE=false → per-product detect (crops/overlay
#   zones/ad-readiness) is deferred to ad-generation time instead of
#   running for the whole catalog at sync time. Set true to restore eager
#   whole-catalog precompute.
# CATALOG_ENRICHMENT_* bound the auto review gap-fill + the user-actuated
#   "Enrich" (cross-seller + web-review) path.
CATALOG_DETECT_PRECOMPUTE=false
CATALOG_ENRICHMENT_CONCURRENCY=6
CATALOG_ENRICHMENT_MAX_PER_RUN=500

